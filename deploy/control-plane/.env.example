# ============================================================
# 星隧 VPN 控制面环境变量样板（大阪 212）
# 复制为 .env 后填写真实值。.env 绝不可提交到 Git。
# 所有占位符均无真实密钥，请用强随机值替换。
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=xingsui
POSTGRES_USER=xingsui
# 用 openssl rand -base64 24 生成
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
# 后端连库地址（compose 已自动覆盖为 db 服务名，此处保持占位即可）
DATABASE_URL=postgresql+psycopg://xingsui:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/xingsui

# ---------- 站点 / 反代 ----------
# 已解析到本机(212)的域名，空格分隔；Caddy 会为每个域名自动签发并续期证书。
# 共 3 条 A 记录（含子域名），按实际解析调整 www / api 子域。
SITE_DOMAIN=xingsuico.com www.xingsuico.com api.xingsuico.com xingsui.org
# Let's Encrypt 到期通知邮箱（建议填写真实邮箱）
ACME_EMAIL=admin@xingsuico.com
# App / 官网跨域来源，逗号分隔；生产建议收敛为具体域名
CORS_ALLOW_ORIGINS=https://xingsuico.com,https://www.xingsuico.com,https://xingsui.org

# ---------- Admin 后台 ----------
# 必须覆盖代码内默认值！用 openssl rand -base64 18 生成
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_RANDOM_SESSION_SECRET

# ---------- App 版本控制 ----------
APP_VERSION_CODE=15
APP_VERSION_NAME=2.0.5
MIN_SUPPORTED_APP_VERSION_CODE=15

# ============================================================
# VPN 节点下发参数
# 控制面不在本机跑 awg，故关闭自动签发。
# 跨机 peer 签发由边缘节点 Agent / SSH 通道完成（下一研发项）。
# ============================================================
VPN_AUTO_PROVISION=false

# ---------- 节点 Agent（方案 A）安全与通信 ----------
# 控制面与边缘节点 Agent 之间的共享令牌（X-Internal-Token）。
# 必须与每个节点 /etc/xingsui/agent.env 的 XS_AGENT_TOKEN 完全一致。
# 用 openssl rand -hex 32 生成。
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN_HEX32
# 默认 Agent 端口（节点表可逐节点覆盖 agent_port）
NODE_AGENT_PORT=51821
# 心跳超过该秒数未更新则判定节点离线
NODE_OFFLINE_AFTER_SECONDS=120
# 调用边缘节点 Agent 的超时（秒）
AGENT_HTTP_TIMEOUT=6

# 下面这组「混淆与节点参数」必须与各边缘节点 awg0.conf 完全一致，
# 否则客户端与服务端握手失败。值由 edge-node 初始化脚本输出后回填。
# 默认节点（首选大阪 VIP 线路）展示信息：
VPN_NODE_ID=jp-osaka-01
VPN_NODE_NAME=日本大阪·精品(CN2 GIA)
VPN_NODE_REGION=日本

# 节点连接参数（占位，按 edge-node 脚本输出回填）
VPN_SERVER_PUBLIC_KEY=PASTE_FROM_EDGE_NODE
VPN_ENDPOINTS=NODE_IP:443
VPN_CLIENT_NETWORK=10.66.66.0/24
VPN_DNS=1.1.1.1
VPN_ALLOWED_IPS=0.0.0.0/0
VPN_PERSISTENT_KEEPALIVE=25
VPN_MTU=1420

# AmneziaWG 抗封锁混淆参数（client/server 必须一致；由 edge-node 脚本生成）
AMNEZIAWG_SERVER_ENABLED=false
AMNEZIA_JC=4
AMNEZIA_JMIN=40
AMNEZIA_JMAX=70
AMNEZIA_S1=86
AMNEZIA_S2=574
# H1-H4 必须为各不相同的大随机数（切勿用默认 1/2/3/4，那会被 DPI 识别）
AMNEZIA_H1=PASTE_FROM_EDGE_NODE
AMNEZIA_H2=PASTE_FROM_EDGE_NODE
AMNEZIA_H3=PASTE_FROM_EDGE_NODE
AMNEZIA_H4=PASTE_FROM_EDGE_NODE
