<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/xingsui_home_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:contentDescription="@string/app_name"
                android:src="@mipmap/ic_launcher_round" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/connection_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/xingsui_home_disconnected"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="#BDEFFAFF" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/smart_mode_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:minWidth="52dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/account_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/xingsui_home_panel"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/account_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="middle"
                        android:singleLine="true"
                        android:text="@string/xingsui_home_guest"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="#FFFFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/traffic_remaining"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="@string/xingsui_home_trial_hint"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="#CFE4F4FF" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/vip_button"
                    android:layout_width="82dp"
                    android:layout_height="44dp"
                    android:text="@string/xingsui_home_recharge"
                    android:textColor="#061223"
                    app:backgroundTint="@color/xingsui_offer_gold"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/auth_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/login_button"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="@string/xingsui_login"
                    android:textColor="#061223"
                    app:backgroundTint="@color/xingsui_cyan"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/register_button"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/xingsui_register"
                    android:textColor="#FFFFFFFF"
                    app:cornerRadius="8dp"
                    app:strokeColor="#66FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="282dp"
            android:layout_marginTop="10dp">

            <View
                android:id="@+id/power_ring"
                android:layout_width="242dp"
                android:layout_height="242dp"
                android:layout_gravity="center"
                android:background="@drawable/xingsui_power_ring" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/connect_button"
                android:layout_width="168dp"
                android:layout_height="168dp"
                android:layout_gravity="center"
                android:background="@drawable/xingsui_connect_button_bg"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/xingsui_home_connect"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="84dp"
                app:elevation="10dp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/xingsui_home_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/xingsui_home_current_node"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="#91B8CA" />

                <TextView
                    android:id="@+id/node_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="@string/xingsui_home_auto_node"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/node_manage_button"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="72dp"
                android:layout_height="42dp"
                android:text="@string/xingsui_home_node_manage"
                android:textColor="#FFFFFFFF"
                app:cornerRadius="8dp"
                app:strokeColor="#66FFFFFF" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refresh_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="@string/xingsui_home_smart_match"
            android:textColor="#061223"
            app:backgroundTint="@color/xingsui_cyan"
            app:cornerRadius="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/xingsui_home_panel"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/xingsui_home_vip_status"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="#91B8CA" />

                <TextView
                    android:id="@+id/vip_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="@string/xingsui_home_vip_inactive"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="92dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/xingsui_home_panel"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/xingsui_home_expiry"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="#91B8CA" />

                <TextView
                    android:id="@+id/vip_expiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/xingsui_home_no_expiry"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="#FFFFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/user_center_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="@string/xingsui_home_user_center"
            android:textColor="#FFFFFFFF"
            app:cornerRadius="8dp"
            app:strokeColor="#66FFFFFF" />
    </LinearLayout>
</ScrollView>
